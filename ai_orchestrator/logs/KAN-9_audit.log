PATH: git-driven-observability/terraform/worker.tf
CODE: terraform {
  required_providers = {
    aws = {
      source   = "hashicorp/aws", # Use the latest version of the AWS Provider for Terraform >5.0
      version  = "+~> 5.0"
    }
  }
}

resource "aws_instance" "worker-node" {
  count         = 1
  instance_type = var.ec2_instance_size # Define the size of your EC2 instance in a variable or environment file beforehand
  availability_zone = var.availability_zone # Specify the zone where you want to deploy this worker-node, typically it's `us-east-1a` for AWS
  
  tags {
    ManagedBy     = "AI-Orchestrator"
    Project       = "Jira-Automation"
    Environment   = var.environment # Define the environment (e.g., 'prod', 'staging') in a variable or an environment file beforehand
  }
}

variable "ec2_instance_size" {
  type        = string
  description = "The size of EC2 instance to deploy."
}

outputs.tf: # Define outputs for later use, if necessary after the deployment process
```terraform
output "worker_node_ip" {
  value = aws_instance.worker-node[0].public_ip
}
```
